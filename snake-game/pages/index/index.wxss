.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.game-info {
  display: flex;
  justify-content: space-between;
  width: 300px;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.score {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

.high-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF9800;
}

.game-canvas {
  border: 4rpx solid #4CAF50;
  border-radius: 10rpx;
  background-color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.controls {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.control-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  align-items: center;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  color: white;
  font-size: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s;
}

.control-btn:active {
  background-color: #388E3C;
  transform: scale(0.95);
}

.instructions {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.instructions text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}
